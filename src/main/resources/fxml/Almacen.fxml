<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="768.0" prefWidth="1024.0" style="-fx-background-color: linear-gradient(to bottom right, #00BFFF, #0055A4);" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.restaurante.controller.AlmacenController">
   <children>
      <Pane layoutX="73.0" layoutY="108.0" prefHeight="500.0" prefWidth="877.0" style="-fx-background-color: #FFF8E1; -fx-background-radius: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 15, 0, 0, 8);">
         <children>
            <Label layoutX="330.0" layoutY="20.0" text="CONTROL DE ALMACÉN" textFill="#ff8f00">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>
            
            <VBox alignment="CENTER_LEFT" layoutX="36.0" layoutY="78.0" prefWidth="224.0" spacing="5.0">
               <children>
                  <Label text="Producto (Ingrediente):" textFill="#263238">
                     <font><Font name="System Bold" size="13.0" /></font>
                  </Label>
                  <TextField fx:id="txtNombre" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #00BFFF; -fx-border-radius: 10; -fx-border-width: 2; -fx-padding: 8;" />
               </children>
            </VBox>
            
            <VBox alignment="CENTER_LEFT" layoutX="36.0" layoutY="148.0" prefWidth="224.0" spacing="5.0">
               <children>
                  <Label text="Cantidad en Stock:" textFill="#263238">
                     <font><Font name="System Bold" size="13.0" /></font>
                  </Label>
                  <TextField fx:id="txtCantidad" promptText="0.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #00BFFF; -fx-border-radius: 10; -fx-border-width: 2; -fx-padding: 8;" />
               </children>
            </VBox>
            
            <VBox alignment="CENTER_LEFT" layoutX="36.0" layoutY="218.0" prefWidth="224.0" spacing="5.0">
               <children>
                  <Label text="Unidad de Medida:" textFill="#263238">
                     <font><Font name="System Bold" size="13.0" /></font>
                  </Label>
                  <ComboBox fx:id="cbUnidad" prefWidth="224.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #00BFFF; -fx-border-radius: 10; -fx-border-width: 2;" />
               </children>
            </VBox>
            
            <VBox alignment="CENTER_LEFT" layoutX="36.0" layoutY="288.0" prefWidth="224.0" spacing="5.0">
               <children>
                  <Label text="Stock Mínimo (Alerta):" textFill="#263238">
                     <font><Font name="System Bold" size="13.0" /></font>
                  </Label>
                  <TextField fx:id="txtStockMinimo" promptText="0.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #00BFFF; -fx-border-radius: 10; -fx-border-width: 2; -fx-padding: 8;" />
               </children>
            </VBox>
            
            <TableView fx:id="tblAlmacen" layoutX="281.0" layoutY="78.0" prefHeight="330.0" prefWidth="560.0" style="-fx-background-radius: 10;">
              <columns>
                <TableColumn fx:id="colNombre" prefWidth="200.0" style="-fx-background-color: #f49c30; -fx-text-fill: white;" text="Producto" />
                <TableColumn fx:id="colCantidad" prefWidth="100.0" style="-fx-background-color: #f49c30; -fx-text-fill: white;" text="Cantidad" />
                <TableColumn fx:id="colUnidad" prefWidth="130.0" style="-fx-background-color: #f49c30; -fx-text-fill: white;" text="Unidad" />
                <TableColumn fx:id="colMinimo" prefWidth="110.0" style="-fx-background-color: #f49c30; -fx-text-fill: white;" text="Stock Mínimo" />
              </columns>
            </TableView>

            <Button layoutX="36.0" layoutY="430.0" mnemonicParsing="false" onAction="#clicLimpiar" prefHeight="40.0" prefWidth="100.0" style="-fx-background-color: #FFB300; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" text="LIMPIAR" />
            <Button layoutX="160.0" layoutY="430.0" mnemonicParsing="false" onAction="#clicGuardar" prefHeight="40.0" prefWidth="100.0" style="-fx-background-color: #00C853; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" text="GUARDAR" />
            <Button layoutX="740.0" layoutY="430.0" mnemonicParsing="false" onAction="#clicVolver" prefHeight="40.0" prefWidth="100.0" style="-fx-background-color: #D32F2F; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" text="VOLVER" />
         </children>
      </Pane>
   </children>
</AnchorPane>