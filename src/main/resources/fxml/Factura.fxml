<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="720.0" prefWidth="1024.0" style="-fx-background-color: #1592c3;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.restaurante.controller.FacturaController">
    <children>

        <VBox spacing="15.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="15.0">

            <children>

                <HBox spacing="15.0">

                    <children>

                        <VBox prefWidth="500.0" spacing="10.0" style="-fx-background-color: #ffeeb2;                                      -fx-background-radius: 15;                                      -fx-border-radius: 15;                                      -fx-border-color: #a68c42;                                      -fx-border-width: 2;">

                            <padding>
                                <Insets bottom="15" left="15" right="15" top="15" />
                            </padding>

                            <children>

                                <Label text="Datos del Cliente (Receptor)">
                                    <font>
                                        <Font size="20" />
                                    </font>
                                </Label>

                                <GridPane hgap="10" vgap="10">

                                    <children>

                                        <Label text="RFC:" GridPane.columnIndex="0" GridPane.rowIndex="0" />

                                        <TextField fx:id="txtRFC" promptText="XXXX000000XXX" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                        <Label text="Razón Social:" GridPane.columnIndex="0" GridPane.rowIndex="1" />

                                        <TextField fx:id="txtNombre" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                        <Label text="Código Postal:" GridPane.columnIndex="0" GridPane.rowIndex="2" />

                                        <TextField fx:id="txtCP" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                        <Label text="Correo Electrónico:" GridPane.columnIndex="0" GridPane.rowIndex="3" />

                                        <TextField fx:id="txtCorreo" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                        <Label text="Uso CFDI:" GridPane.columnIndex="0" GridPane.rowIndex="4" />

                                        <ComboBox fx:id="cbUsoCFDI" prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                                        <Label text="Régimen Fiscal:" GridPane.columnIndex="0" GridPane.rowIndex="5" />

                                        <ComboBox fx:id="cbRegimenReceptor" prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                                    </children>
                           <columnConstraints>
                              <ColumnConstraints />
                              <ColumnConstraints />
                           </columnConstraints>
                           <rowConstraints>
                              <RowConstraints />
                              <RowConstraints />
                              <RowConstraints />
                              <RowConstraints />
                              <RowConstraints />
                              <RowConstraints />
                           </rowConstraints>

                                </GridPane>

                            </children>

                        </VBox>

                        <VBox prefWidth="450.0" spacing="10.0" style="-fx-background-color: #ffeeb2;                                      -fx-background-radius: 15;                                      -fx-border-radius: 15;                                      -fx-border-color: #a68c42;                                      -fx-border-width: 2;">

                            <padding>
                                <Insets bottom="15" left="15" right="15" top="15" />
                            </padding>

                            <children>

                                <Label text="Datos de la Factura (Maestro)">
                                    <font>
                                        <Font size="20" />
                                    </font>
                                </Label>

                                <GridPane hgap="10" vgap="10">

                                    <children>

                                        <Label text="Folio:" GridPane.columnIndex="0" GridPane.rowIndex="0" />

                                        <TextField fx:id="txtFolio" editable="false" promptText="A-0045" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                        <Label text="Fecha:" GridPane.columnIndex="0" GridPane.rowIndex="1" />

                                        <TextField fx:id="txtFecha" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                        <Label text="Forma de Pago:" GridPane.columnIndex="0" GridPane.rowIndex="2" />

                                        <ComboBox fx:id="cbFormaPago" prefWidth="250" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                    </children>
                           <columnConstraints>
                              <ColumnConstraints />
                              <ColumnConstraints />
                           </columnConstraints>
                           <rowConstraints>
                              <RowConstraints />
                              <RowConstraints />
                              <RowConstraints />
                           </rowConstraints>

                                </GridPane>

                            </children>

                        </VBox>

                    </children>

                </HBox>

                <VBox spacing="10" style="-fx-background-color: #ffeeb2;                              -fx-background-radius: 15;                              -fx-border-radius: 15;                              -fx-border-color: #a68c42;                              -fx-border-width: 2;" VBox.vgrow="ALWAYS">

                    <padding>
                        <Insets bottom="15" left="15" right="15" top="15" />
                    </padding>

                    <children>

                        <Label text="Conceptos del Consumo (Detalle)">
                            <font>
                                <Font size="20" />
                            </font>
                        </Label>

                        <TableView fx:id="tvFactura" VBox.vgrow="ALWAYS">

                            <columns>

                                <TableColumn fx:id="colClave" prefWidth="150" text="Clave Prod/Serv" />

                                <TableColumn fx:id="colCantidad" prefWidth="100" text="Cantidad" />

                                <TableColumn fx:id="colUnidad" prefWidth="150" text="Unidad" />

                                <TableColumn fx:id="colPlatillo" prefWidth="350" text="Descripción" />

                                <TableColumn fx:id="colPrecio" prefWidth="120" text="P. Unitario" />

                                <TableColumn fx:id="colTotal" prefWidth="120" text="Importe" />

                            </columns>

                        </TableView>

                    </children>

                </VBox>

                <HBox spacing="30">

                    <children>

                        <VBox spacing="10">

                            <children>

                                <Label text="Totales Matemáticos">
                                    <font>
                                        <Font size="20" />
                                    </font>
                                </Label>

                                <GridPane hgap="10" vgap="10">

                                    <children>

                                        <Label text="Subtotal" GridPane.columnIndex="0" GridPane.rowIndex="0" />

                                        <TextField fx:id="txtSubtotal" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                        <Label text="IVA (16%)" GridPane.columnIndex="0" GridPane.rowIndex="1" />

                                        <TextField fx:id="txtIVA" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                        <Label text="TOTAL GENERAL ($)" GridPane.columnIndex="0" GridPane.rowIndex="2" />

                                        <TextField fx:id="txtTotalGeneral" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                    </children>
                           <columnConstraints>
                              <ColumnConstraints />
                              <ColumnConstraints />
                           </columnConstraints>
                           <rowConstraints>
                              <RowConstraints />
                              <RowConstraints />
                              <RowConstraints />
                           </rowConstraints>

                                </GridPane>

                            </children>

                        </VBox>

                        <VBox alignment="CENTER_RIGHT" spacing="15" HBox.hgrow="ALWAYS">

                            <children>

                                <Button fx:id="btnVolver" onAction="#volverDashboard" prefHeight="45" prefWidth="250" style="-fx-background-color: #d9534f;                                                -fx-text-fill: white;                                                -fx-font-size: 14;                                                -fx-font-weight: bold;" text="Volver al Dashboard" />

                                <Button fx:id="btnGenerarFactura" onAction="#btnGenerarFacturaAction" prefHeight="45" prefWidth="250" style="-fx-background-color: #5cb85c;                                                -fx-text-fill: white;                                                -fx-font-size: 14;                                                -fx-font-weight: bold;" text="Generar Factura (PDF)" />

                            </children>

                        </VBox>

                    </children>

                </HBox>

            </children>

        </VBox>

    </children>

</AnchorPane>
