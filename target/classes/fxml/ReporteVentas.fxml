<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="768.0" prefWidth="1024.0" style="-fx-background-color: linear-gradient(to bottom right, #00BFFF, #0055A4);" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.restaurante.controller.ReporteVentasController">
   <children>
      <Pane layoutX="57.0" layoutY="73.0" prefHeight="622.0" prefWidth="911.0" style="-fx-background-color: #FFF8E1; -fx-background-radius: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 15, 0, 0, 8);">
         <children>
            <Label layoutX="324.0" layoutY="20.0" text="REPORTE DE VENTAS" textFill="#ff8f00">
               <font>
                  <Font name="System Bold" size="26.0" />
               </font>
            </Label>
            
            <DatePicker fx:id="dpFechaInicio" layoutX="50.0" layoutY="90.0" prefHeight="35.0" prefWidth="180.0" promptText="Fecha Inicio" style="-fx-border-color: #00BFFF; -fx-border-radius: 5;" />
            <DatePicker fx:id="dpFechaFin" layoutX="250.0" layoutY="90.0" prefHeight="35.0" prefWidth="180.0" promptText="Fecha Fin" style="-fx-border-color: #00BFFF; -fx-border-radius: 5;" />
            <Button layoutX="450.0" layoutY="90.0" mnemonicParsing="false" onAction="#clicBuscar" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #00BFFF; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" text="BUSCAR" />
            <Button layoutX="570.0" layoutY="90.0" mnemonicParsing="false" onAction="#clicGenerarMensual" prefHeight="35.0" prefWidth="140.0" style="-fx-background-color: #0055A4; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" text="MES ACTUAL" />
            
            <TableView fx:id="tblVentas" layoutX="50.0" layoutY="150.0" prefHeight="350.0" prefWidth="420.0" style="-fx-background-radius: 10;">
              <columns>
                <TableColumn fx:id="colFecha" prefWidth="210.0" style="-fx-background-color: #f49c30; -fx-text-fill: white;" text="Día / Mes" />
                <TableColumn fx:id="colTotal" prefWidth="200.0" style="-fx-background-color: #f49c30; -fx-text-fill: white;" text="Total Ingresos ($)" />
              </columns>
            </TableView>

            <TableView fx:id="tblProductos" layoutX="490.0" layoutY="150.0" prefHeight="350.0" prefWidth="380.0" style="-fx-background-radius: 10;">
              <columns>
                <TableColumn fx:id="colPlatillo" prefWidth="250.0" style="-fx-background-color: #005a96; -fx-text-fill: white;" text="Platillo Más Vendido" />
                <TableColumn fx:id="colCantidad" prefWidth="120.0" style="-fx-background-color: #005a96; -fx-text-fill: white;" text="Unidades" />
              </columns>
            </TableView>

            <Label layoutX="140.0" layoutY="520.0" text="Total del Periodo Seleccionado:" textFill="#263238">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
            </Label>
            <Label fx:id="lblTotalPeriodo" layoutX="419.0" layoutY="520.0" text="\$0.00" textFill="#00c853">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
            </Label>

            <Button layoutX="50.0" layoutY="555.0" mnemonicParsing="false" onAction="#clicVolver" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #E53935; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" text="VOLVER" />
         </children>
      </Pane>
   </children>
</AnchorPane>